{
  "manifest_version": 3,
  "name": "NodeShield AI AdBlocker",
  "version": "2.0",
  "permissions": [
    "declarativeNetRequest",
    "webRequest",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}