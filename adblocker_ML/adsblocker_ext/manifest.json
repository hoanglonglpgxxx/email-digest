{
  "manifest_version": 3,
  "name": "NodeShield AI Guard",
  "version": "1.0",
  "description": "Bảo vệ trình duyệt bằng AI dựa trên cấu trúc DOM",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["http://localhost:8000/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}