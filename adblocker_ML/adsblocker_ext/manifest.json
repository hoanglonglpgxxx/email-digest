{
  "manifest_version": 3,
  "name": "AI Adblocker",
  "version": "2.0",
  "permissions": [
    "declarativeNetRequest",
    "webRequest",
    "offscreen",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}