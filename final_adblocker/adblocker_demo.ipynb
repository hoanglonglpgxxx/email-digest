    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Adblocker Random Forest Demo (Jupyter)\\n\",\n",
    "    \"Walk-through of the classic ad dataset using the original Random Forest pipeline.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"%matplotlib inline\\n\",\n",
    "    \"import time\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"from sklearn.model_selection import train_test_split, cross_val_score\\n\",\n",
    "    \"from sklearn.ensemble import RandomForestClassifier\\n\",\n",
    "    \"from sklearn.metrics import classification_report, confusion_matrix\\n\",\n",
    "    \"import joblib\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Helper functions\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"def load_and_clean_data(filepath=\\\"ad.data\\\"):\\n\",\n",
    "    \"    \\\"\\\"\\\"Load the raw ad dataset and drop rows with missing values.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n[1/6] Loading and cleaning data...\\\")\\n\",\n",
    "    \"    start_time = time.time()\\n\",\n",
    "    \"    df = pd.read_csv(filepath, header=None, low_memory=False)\\n\",\n",
    "    \"    df.rename(columns={1558: \\\"label\\\"}, inplace=True)\\n\",\n",
    "    \"    df = df.replace(to_replace='[?]', value=np.nan, regex=True)\\n\",\n",
    "    \"    initial_len = len(df)\\n\",\n",
    "    \"    df.dropna(inplace=True)\\n\",\n",
    "    \"    final_len = len(df)\\n\",\n",
    "    \"    feature_cols = df.columns[:-1]\\n\",\n",
    "    \"    df[feature_cols] = df[feature_cols].apply(pd.to_numeric)\\n\",\n",
    "    \"    print(f\\\"   -> Removed {initial_len - final_len} rows containing errors/missing values.\\\")\\n\",\n",
    "    \"    print(f\\\"   -> Processing time: {time.time() - start_time:.2f} seconds.\\\")\\n\",\n",
    "    \"    return df\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def prepare_data(df):\\n\",\n",
    "    \"    \\\"\\\"\\\"Split train/test and map labels to binary.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n[2/6] Splitting Train/Test sets...\\\")\\n\",\n",
    "    \"    df[\\\"label\\\"] = df[\\\"label\\\"].apply(lambda x: 1 if str(x).strip() == \\\"ad.\\\" else 0)\\n\",\n",
    "    \"    X = df.drop(\\\"label\\\", axis=1).values\\n\",\n",
    "    \"    y = df[\\\"label\\\"].values\\n\",\n",
    "    \"    X_train, X_test, y_train, y_test = train_test_split(X, y)\\n\",\n",
    "    \"    return X_train, X_test, y_train, y_test\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def train_model(X_train, y_train):\\n\",\n",
    "    \"    \\\"\\\"\\\"Train a baseline RandomForest classifier.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n[3/6] Training Random Forest Classifier...\\\")\\n\",\n",
    "    \"    clf = RandomForestClassifier()\\n\",\n",
    "    \"    clf.fit(X_train, y_train)\\n\",\n",
    "    \"    return clf\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def evaluate_model(clf, X_train, y_train, X_test, y_test):\\n\",\n",
    "    \"    \\\"\\\"\\\"Evaluate accuracy and run 5-fold cross-validation; export report to CSV.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n[4/6] Evaluating model performance...\\\")\\n\",\n",
    "    \"    score = clf.score(X_test, y_test)\\n\",\n",
    "    \"    print(f\\\"   -> Test Set Accuracy: {score * 100:.2f}%\\\")\\n\",\n",
    "    \"    print(\\\"   -> Running 5-Fold Cross-Validation...\\\")\\n\",\n",
    "    \"    cv_scores = cross_val_score(clf, X_train, y_train, cv=5)\\n\",\n",
    "    \"    table_data = []\\n\",\n",
    "    \"    for i, s in enumerate(cv_scores):\\n\",\n",
    "    \"        table_data.append({\\\"Fold\\\": f\\\"Run {i + 1}\\\", \\\"Accuracy\\\": s, \\\"Formatted\\\": f\\\"{s * 100:.2f}%\\\"})\\n\",\n",
    "    \"    mean_score = cv_scores.mean()\\n\",\n",
    "    \"    std_score = cv_scores.std()\\n\",\n",
    "    \"    table_data.append({\\\"Fold\\\": \\\"AVERAGE\\\", \\\"Accuracy\\\": mean_score, \\\"Formatted\\\": f\\\"{mean_score * 100:.2f}% (+/- {std_score * 100:.2f}%)\\\"})\\n\",\n",
    "    \"    df_cv_report = pd.DataFrame(table_data)\\n\",\n",
    "    \"    print(\\\"\\\\nCROSS-VALIDATION REPORT\\\\n\\\" + \\\"=\\\" * 40)\\n\",\n",
    "    \"    print(df_cv_report[[\\\"Fold\\\", \\\"Formatted\\\"]].to_string(index=False))\\n\",\n",
    "    \"    df_cv_report.to_csv(\\\"cross_validation_report.csv\\\", index=False)\\n\",\n",
    "    \"    print(\\\"   -> Report exported to: 'cross_validation_report.csv'\\\")\\n\",\n",
    "    \"    return cv_scores, mean_score, std_score\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def detailed_report(clf, X_test, y_test):\\n\",\n",
    "    \"    \\\"\\\"\\\"Print classification report.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n[5/6] Generating detailed classification report...\\\")\\n\",\n",
    "    \"    y_pred = clf.predict(X_test)\\n\",\n",
    "    \"    print(classification_report(y_test, y_pred, target_names=[\\\"Non-Ad\\\", \\\"Ad\\\"]))\\n\",\n",
    "    \"    return y_pred\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def visualize_results(clf, y_test, y_pred, cv_scores, cv_mean):\\n\",\n",
    "    \"    \\\"\\\"\\\"Plot cross-validation scores, confusion matrix, and feature importance.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(\\\"\\\\n[6/6] Visualizing results...\\\")\\n\",\n",
    "    \"    plt.figure(figsize=(14, 6))\\n\",\n",
    "    \"    plt.subplot(1, 2, 1)\\n\",\n",
    "    \"    folds = [f\\\"Run {i + 1}\\\" for i in range(len(cv_scores))]\\n\",\n",
    "    \"    bars = plt.bar(folds, cv_scores, color='#4e79a7', alpha=0.8)\\n\",\n",
    "    \"    plt.axhline(cv_mean, color='red', linestyle='--', linewidth=2, label=f'Average: {cv_mean * 100:.2f}%')\\n\",\n",
    "    \"    for bar in bars:\\n\",\n",
    "    \"        height = bar.get_height()\\n\",\n",
    "    \"        plt.text(bar.get_x() + bar.get_width() / 2., height, f'{height * 100:.1f}%', ha='center', va='bottom')\\n\",\n",
    "    \"    plt.ylim(0.8, 1.0)\\n\",\n",
    "    \"    plt.ylabel('Accuracy')\\n\",\n",
    "    \"    plt.title('Cross-Validation Scores (5-Folds)')\\n\",\n",
    "    \"    plt.legend(loc='lower right')\\n\",\n",
    "    \"    plt.grid(axis='y', linestyle='--', alpha=0.5)\\n\",\n",
    "    \"    plt.subplot(1, 2, 2)\\n\",\n",
    "    \"    cm = confusion_matrix(y_test, y_pred)\\n\",\n",
    "    \"    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', xticklabels=[\\\"Non-Ad (Predicted)\\\", \\\"Ad (Predicted)\\\"], yticklabels=[\\\"Non-Ad (Actual)\\\", \\\"Ad (Actual)\\\"])\\n\",\n",
    "    \"    plt.title('Confusion Matrix')\\n\",\n",
    "    \"    plt.ylabel('Actual Label')\\n\",\n",
    "    \"    plt.xlabel('Predicted Label')\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"    plt.figure(figsize=(10, 6))\\n\",\n",
    "    \"    importances = clf.feature_importances_\\n\",\n",
    "    \"    indices = np.argsort(importances)[::-1][:10]\\n\",\n",
    "    \"    plt.title('Top 10 Most Important Features')\\n\",\n",
